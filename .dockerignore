# Secrets - NEVER include in image
.env
.env.*
.env.backup
*.pem
*.key
credentials.json
service-account*.json

# Development artifacts
node_modules
dist
build
.git
.gitignore

# IDE and editor files
.vscode
.idea
*.swp
*.swo

# Test artifacts
coverage
e2e/test-results
playwright-report

# Large binaries
*.dmg
*.exe
*.app

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Documentation (not needed in runtime)
docs/
*.md
!README.md

# Landing page (separate build)
landing-page/
