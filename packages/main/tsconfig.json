{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "declaration": false,
        "outDir": "../../dist/main",
        "rootDir": "src",
        "paths": {
            "@shared/*": [
                "../shared/src/*"
            ]
        }
    },
    "include": [
        "src"
    ],
    "references": [
        {
            "path": "../shared"
        }
    ]
}