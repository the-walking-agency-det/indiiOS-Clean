# ============================================================
# App Configuration
# ============================================================
VITE_API_KEY=your_gemini_api_key_here
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GOOGLE_DEVKNOWLEDGE_API_KEY=your_developer_knowledge_api_key
VITE_SKIP_ONBOARDING=false
DEV=false

# ============================================================
# Google Cloud / Vertex AI
# ============================================================
VITE_VERTEX_PROJECT_ID=indiios-v-1-1
VITE_VERTEX_LOCATION=us-central1
VITE_USE_VERTEX=false
GCLOUD_PROJECT=your_project_id

# ============================================================
# Backend URLs
# ============================================================
VITE_FUNCTIONS_URL=https://us-central1-your-project.cloudfunctions.net
VITE_RAG_PROXY_URL=https://us-central1-your-project.cloudfunctions.net/ragProxy
# Agent Zero sidecar URL (defaults to http://localhost:50080 if not set)
# Override for staging/prod: VITE_AGENT_ZERO_URL=https://your-sidecar-host
VITE_AGENT_ZERO_URL=http://localhost:50080

# ============================================================
# Firebase Configuration (Frontend)
# Get these values from your Firebase Console -> Project Settings
# ============================================================
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_DATABASE_URL=https://your_project_id.firebaseio.com

# ============================================================
# App Check Configuration
# Required for production AI usage
# ============================================================
VITE_FIREBASE_APP_CHECK_KEY=your_recaptcha_site_key
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=your_debug_token_for_local_testing

# ============================================================
# Sentry Error Tracking (Production)
# Get DSN from https://sentry.io -> Project Settings -> Client Keys
# ============================================================
VITE_SENTRY_DSN=
VITE_APP_VERSION=0.1.0-beta.2

# ============================================================
# Landing Page URL (for Electron auth flow)
# ============================================================
VITE_LANDING_PAGE_URL=https://indiios-v-1-1.web.app/login-bridge

# ============================================================
# Firebase Configuration (Scripts/Admin)
# Used by Node.js scripts in /scripts and Cloud Functions
# ============================================================
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_APP_ID=your_firebase_app_id
# GOD_MODE_EMAILS=admin@example.com,tester@example.com

# ============================================================
# Automator Credentials (for automated testing scripts)
# ============================================================
AUTOMATOR_EMAIL=automator@example.com
AUTOMATOR_PASSWORD=your_secure_password_here

# ============================================================
# Local Development Secrets (Emulator / Functions)
# ============================================================
# INNGEST_EVENT_KEY=local_event_key
# INNGEST_SIGNING_KEY=local_signing_key
# GEMINI_API_KEY=your_gemini_api_key
