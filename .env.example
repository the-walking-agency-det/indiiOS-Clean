# ============================================================================
# indiiOS Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Firebase Configuration
# Get these values from: Firebase Console -> Project Settings -> General
# ----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ----------------------------------------------------------------------------
# Google AI / Vertex AI Configuration
# ----------------------------------------------------------------------------
# Primary API Key for Gemini/Imagen (Google AI Studio or Vertex AI)
VITE_API_KEY=your_gemini_api_key_here

# Vertex AI specific (optional - only if using Vertex AI backend)
VITE_VERTEX_PROJECT_ID=your_gcp_project_id
VITE_VERTEX_LOCATION=us-central1
VITE_USE_VERTEX=false

# ----------------------------------------------------------------------------
# Backend Services
# ----------------------------------------------------------------------------
# Firebase Functions URL (auto-detected in production)
VITE_FUNCTIONS_URL=https://us-central1-your_project_id.cloudfunctions.net

# RAG Proxy (for local development only)
VITE_RAG_PROXY_URL=http://localhost:3001

# API Base URL (if using custom backend)
VITE_API_BASE_URL=https://api.indiios.com/v1

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
VITE_USE_MOCK_API=false
VITE_USE_REMOTE_STORAGE=true

# Enable fine-tuned agent models (requires populated fine-tuned-models.ts registry)
VITE_USE_FINE_TUNED_AGENTS=false

# Skip onboarding flow in development (set to "true" to go straight to dashboard)
VITE_SKIP_ONBOARDING=false

# ----------------------------------------------------------------------------
# Electron / Desktop App
# ----------------------------------------------------------------------------
# Landing page URL for OAuth redirect
VITE_LANDING_PAGE_URL=https://indiios-v-1-1.web.app/login-bridge

# ----------------------------------------------------------------------------
# Testing (E2E / Integration Tests)
# ----------------------------------------------------------------------------
# DO NOT use real user credentials - create dedicated test accounts
AUDITOR_EMAIL=
AUDITOR_PASSWORD=
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_STUDIO_URL=http://localhost:4242

# ----------------------------------------------------------------------------
# Google Cloud (for scripts and CI/CD)
# ----------------------------------------------------------------------------
GCLOUD_PROJECT=your_gcp_project_id

# ----------------------------------------------------------------------------
# Integrations, 3rd Party APIs & Advanced Configuration
# ----------------------------------------------------------------------------
# Analytics & Advertising
VITE_APPLE_MUSIC_DEV_TOKEN=
VITE_META_APP_ID=
VITE_TIKTOK_CLIENT_KEY=
VITE_SPOTIFY_CLIENT_ID=

# Email & Auth Providers
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=

# Blockchain & Web3
VITE_ALCHEMY_API_KEY=
VITE_ETH_RPC_URL=
VITE_OPENSEA_API_KEY=
VITE_PINATA_API_KEY=
VITE_PINATA_GATEWAY=
VITE_PINATA_JWT=
VITE_PINATA_SECRET=
VITE_SONGSHARES_BYTECODE=
VITE_UD_API_KEY=
VITE_WALLETCONNECT_PROJECT_ID=

# Legal & E-Signature
VITE_DOCUSIGN_ACCESS_TOKEN=
VITE_DOCUSIGN_ACCOUNT_ID=
VITE_DOCUSIGN_BASE_URL=
VITE_NOTARIZE_API_KEY=

# Distribution & DDEX
VITE_DDEX_DPID_AMAZON=
VITE_DDEX_DPID_APPLE=
VITE_DDEX_DPID_DEEZER=
VITE_DDEX_DPID_SPOTIFY=
VITE_DDEX_DPID_TIDAL=
VITE_DDEX_DPID_YOUTUBE=
VITE_DDEX_LIVE_MODE=false
VITE_AMAZON_SFTP_HOST=
VITE_DEEZER_SFTP_HOST=
VITE_SPOTIFY_SFTP_HOST=
VITE_TIDAL_SFTP_HOST=

# Merchandise & Manufacturing
VITE_PRINTFUL_API_KEY=

# Marketing Sites
VITE_EPK_BASE_URL=
VITE_PRESAVE_BASE_URL=

# Media Processing
VITE_REMOTION_BUNDLE_PATH=
VITE_REMOTION_SITE_NAME=

# Realtime & WebSockets
VITE_WEBSOCKET_URL=

# Observability
VITE_APP_VERSION=
VITE_DEBUG_SENTRY=false
VITE_SENTRY_DSN=

# Firebase Advanced
VITE_FCM_VAPID_KEY=
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=
VITE_FIREBASE_APP_CHECK_KEY=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_VAPID_KEY=
VITE_USE_FUNCTIONS_EMULATOR=false

# Google DevKnowledge API
VITE_GOOGLE_DEVKNOWLEDGE_API_KEY=

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_KEY=

# Misc APIs
VITE_API_URL=
VITE_FUNCTIONS_BASE_URL=

# System Flags & Debug
VITE_EXPOSE_INTERNALS=false
VITE_SHOW_DEV_MODULES=false

# ----------------------------------------------------------------------------
# Agent0 & Python Sidecar Subsystem
# ----------------------------------------------------------------------------
VITE_A0_AUTH_LOGIN=
VITE_A0_AUTH_PASSWORD=
VITE_A0_BASE_URL=
VITE_A0_RUNTIME_ID=
