# ============================================================================
# indiiOS Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Firebase Configuration
# Get these values from: Firebase Console -> Project Settings -> General
# ----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ----------------------------------------------------------------------------
# Google AI / Vertex AI Configuration
# ----------------------------------------------------------------------------
# Primary API Key for Gemini/Imagen (Google AI Studio or Vertex AI)
VITE_API_KEY=your_gemini_api_key_here

# Vertex AI specific (optional - only if using Vertex AI backend)
VITE_VERTEX_PROJECT_ID=your_gcp_project_id
VITE_VERTEX_LOCATION=us-central1
VITE_USE_VERTEX=false

# ----------------------------------------------------------------------------
# Backend Services
# ----------------------------------------------------------------------------
# Firebase Functions URL (auto-detected in production)
VITE_FUNCTIONS_URL=https://us-central1-your_project_id.cloudfunctions.net

# RAG Proxy (for local development only)
VITE_RAG_PROXY_URL=http://localhost:3001

# API Base URL (if using custom backend)
VITE_API_BASE_URL=https://api.indiios.com/v1

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
VITE_USE_MOCK_API=false
VITE_USE_REMOTE_STORAGE=true

# ----------------------------------------------------------------------------
# Electron / Desktop App
# ----------------------------------------------------------------------------
# Landing page URL for OAuth redirect
VITE_LANDING_PAGE_URL=https://indiios-v-1-1.web.app/login-bridge

# ----------------------------------------------------------------------------
# Testing (E2E / Integration Tests)
# ----------------------------------------------------------------------------
# DO NOT use real user credentials - create dedicated test accounts
AUDITOR_EMAIL=
AUDITOR_PASSWORD=
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
E2E_STUDIO_URL=http://localhost:4242

# ----------------------------------------------------------------------------
# Google Cloud (for scripts and CI/CD)
# ----------------------------------------------------------------------------
GCLOUD_PROJECT=your_gcp_project_id
