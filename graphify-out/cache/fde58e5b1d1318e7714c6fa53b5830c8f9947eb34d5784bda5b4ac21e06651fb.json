e": "EXTRACTED", "source_file": "/Volumes/X SSD 2025/Users/narrowchannel/Desktop/indiiOS-Clean/packages/renderer/src/services/places/NearbyPlacesService.ts", "source_location": "L161", "weight": 1.0}, {"source": "volumes_x_ssd_2025_users_narrowchannel_desktop_indiios_clean_packages_renderer_src_services_places_nearbyplacesservice_ts", "target": "nearbyplacesservice_navigatetoplace", "relation": "contains", "confidence": "EXTRACTED", "source_file": "/Volumes/X SSD 2025/Users/narrowchannel/Desktop/indiiOS-Clean/packages/renderer/src/services/places/NearbyPlacesService.ts", "source_location": "L235", "weight": 1.0}, {"source": "nearbyplacesservice_searchnearbyplaces", "target": "nearbyplacesservice_ensuregooglemapsloaded", "relation": "calls", "confidence": "EXTRACTED", "source_file": "/Volumes/X SSD 2025/Users/narrowchannel/Desktop/indiiOS-Clean/packages/renderer/src/services/places/NearbyPlacesService.ts", "source_location": "L171", "weight": 1.0}], "raw_calls": [{"caller_nid": "nearbyplacesservice_ensuregooglemapsloaded", "callee": "(async () => {\n        if (typeof window === 'undefined') {\n            throw new Error('Browser environment required for Google Maps API');\n        }\n\n        // Case 1: Places library is already loaded (by TourMap or MapsTools)\n        if (typeof google !== 'undefined' && google.maps?.places?.PlacesService) {\n            return;\n        }\n\n        // Case 2: Google Maps core is loaded but Places isn't \u2014 use importLibrary\n        if (typeof google !== 'undefined' && google.maps?.importLibrary) {\n            logger.info('[NearbyPlaces] Loading Places library via importLibrary...');\n            await google.maps.importLibrary('places');\n            return;\n        }\n\n        // Case 3: Google Maps not loaded at all \u2014 load the full script\n        const apiKey = env.googleMapsApiKey;\n        if (!apiKey) {\n            throw new Error('Missing VITE_GOOGLE_MAPS_API_KEY \u2014 cannot search nearby places');\n        }\n\n        await new Promise<void>((resolve, reject) => {\n            // Check if script is already being loaded by another component\n            const existingScript = document.querySelector('script[src*=\"maps.googleapis.com\"]');\n            if (existingScript) {\n                // Wait for it to load, then import Places\n                const waitForLoad = () => {\n                    if (typeof google !== 'undefined' && google.maps?.importLibrary) {\n                        google.maps.importLibrary('places').then(() => resolve()).catch(reject);\n                    } else {\n                        setTimeout(waitForLoad, 200);\n                    }\n                };\n                waitForLoad();\n                return;\n            }\n\n            const script = document.createElement('script');\n            script.src = `https://maps.googleapis.com/maps/api/js?key=${apiKey}&libraries=places`;\n            script.async = true;\n            script.defer = true;\n            script.onload = () => resolve();\n            script.onerror = (err) => reject(err);\n            document.head.appendChild(script);\n        });\n    })", "source_file": "/Volumes/X SSD 2025/Users/narrowchannel/Desktop/indiiOS-Clean/packages/renderer/src/services/places/NearbyPlacesService.ts", "source_location": "L69"}, {"caller_nid": "nearbyplacesservice_ensuregooglemapsloaded", "callee": "catch", "source_file": "/Volumes/X SSD 2025/Users/narrowchannel/Desktop/indiiOS-Clean/packages/renderer/src/services/places/NearbyPlacesService.ts", "source_location": "L119"}, {"caller_nid": "nearbyplacesservice_haversinedistance", "callee": "sin", "source_file": "/Volumes/X SSD 2025/Users/narrowchannel/Desktop/indiiOS-Clean/packages/renderer/src/services/places/NearbyPlacesService.ts", "source_location": "L134"}, {"caller_nid": "nearbyplacesservice_haversinedistance", "callee": "sin", "source_file": "/Volumes/X SSD 2025/Users/narrowchannel/Desktop/indiiOS-Clean/packages/renderer/src/s