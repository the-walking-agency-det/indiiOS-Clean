rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // Helper Functions
    // =========================================================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null && request.appCheck != null;
    }
    
    // Check if user is authenticated with email (not anonymous)
    function isEmailAuthenticated() {
      return isAuthenticated() && request.auth.token.email != null;
    }
    
    // Check if user owns this resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is member of organization
    function isOrgMember(orgId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/organizations/$(orgId)) &&
        request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
    }
    
    // Check if user is owner of organization
    function isOrgOwner(orgId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid;
    }

    // Validate string field
    function isValidString(field, minLen, maxLen) {
      return field is string && field.size() >= minLen && field.size() <= maxLen;
    }

    // =========================================================================
    // User Profiles
    // =========================================================================
    match /users/{userId} {
      // Users can read their own profile
      allow read: if isOwner(userId);

      // Users can create their own profile
      allow create: if isOwner(userId);

      // Users can update their own profile with validation
      allow update: if isOwner(userId) &&
        // Prevent changing uid
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid']));

      // Users cannot delete their profile (admin action only)
      allow delete: if false;

      // ── Memory Inbox (agent handshake requests) ──────────────────────────
      match /memoryInbox/{itemId} {
        // Only the owning user can read their inbox items
        allow read: if isOwner(userId);
        // Agent backend writes new handshake requests; user can update status only
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
        allow delete: if false;
      }
    }

    // =========================================================================
    // Organizations
    // =========================================================================
    match /organizations/{orgId} {
      // Members can read org data
      allow read: if isOrgMember(orgId);
      
      // Authenticated users with email can create orgs
      allow create: if isEmailAuthenticated() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.auth.uid in request.resource.data.members;
      
      // Only org owner can update
      allow update: if isOrgOwner(orgId) &&
        // Cannot change owner without explicit transfer
        request.resource.data.ownerId == resource.data.ownerId;
      
      // Only org owner can delete
      allow delete: if isOrgOwner(orgId);
      
      // Projects subcollection
      match /projects/{projectId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOrgMember(orgId);
        allow delete: if isOrgOwner(orgId);
        
        // Project history
        match /history/{historyId} {
          allow read: if isOrgMember(orgId);
          allow write: if isOrgMember(orgId);
        }
      }
    }

    // =========================================================================
    // SOCIAL LAYER - Follows, Activity, Posts
    // =========================================================================
    
    // Follow relationships
    match /social_follows/{followId} {
      // Anyone can read follow relationships (public social graph)
      allow read: if isAuthenticated();
      
      // Users can create follows where they are the follower
      allow create: if isAuthenticated() &&
        request.resource.data.followerId == request.auth.uid &&
        request.resource.data.followerId != request.resource.data.followingId && // Can't follow self
        isValidString(request.resource.data.followingId, 1, 128);
      
      // Users can only delete their own follows (unfollow)
      allow delete: if isAuthenticated() &&
        resource.data.followerId == request.auth.uid;
      
      // No updates allowed - delete and recreate
      allow update: if false;
    }
    
    // Activity feed items
    match /social_activity/{activityId} {
      // Anyone authenticated can read activity (for feeds)
      allow read: if isAuthenticated();
      
      // Users can create activity for themselves
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.type in ['follow', 'post', 'release', 'achievement', 'collaboration', 'product_drop'] &&
        request.resource.data.timestamp == request.time;
      
      // Users can delete their own activity
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      
      // No updates - activity is immutable
      allow update: if false;
    }
    
    // User social stats (follower/following counts)
    match /social_stats/{userId} {
      // Public read for profile display
      allow read: if isAuthenticated();
      
      // Initial stats can be created by the user
      allow create: if isOwner(userId);
      
      // Counters are READ-ONLY for clients (Item 205 fix)
      // Must be updated via Cloud Functions trigger or internal batch
      allow update: if false;
    }

    // =========================================================================
    // COMMERCE ENGINE - Products, Transactions, Carts
    // =========================================================================
    
    // Products / Marketplace listings
    match /products/{productId} {
      // Anyone authenticated can browse products
      allow read: if isAuthenticated();
      
      // Sellers can create products
      allow create: if isAuthenticated() &&
        request.resource.data.sellerId == request.auth.uid &&
        request.resource.data.type in ['digital', 'physical', 'nft', 'subscription'] &&
        request.resource.data.status in ['draft', 'active'] &&
        request.resource.data.price >= 0 &&
        isValidString(request.resource.data.title, 1, 200);
      
      // Sellers can update their own products
      allow update: if isAuthenticated() &&
        resource.data.sellerId == request.auth.uid &&
        // Cannot change seller
        request.resource.data.sellerId == resource.data.sellerId;
      
      // Sellers can delete their own products (soft delete preferred)
      allow delete: if isAuthenticated() &&
        resource.data.sellerId == request.auth.uid;
    }
    
    // Transactions / Purchase records
    match /transactions/{transactionId} {
      // Users can read their own transactions (as buyer or seller)
      allow read: if isAuthenticated() &&
        (resource.data.buyerId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid);
      
      // Buyers can create transactions (initiate purchase)
      allow create: if isAuthenticated() &&
        request.resource.data.buyerId == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        request.resource.data.amount >= 0 &&
        request.resource.data.createdAt == request.time;
      
      // Status updates should go through Cloud Functions for payment verification
      // Allow limited updates for status progression
      allow update: if isAuthenticated() &&
        (resource.data.buyerId == request.auth.uid || 
         resource.data.sellerId == request.auth.uid) &&
        // Only status can change, and only to valid next states
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
        (
          // Buyer can cancel pending
          (resource.data.buyerId == request.auth.uid && 
           resource.data.status == 'pending' && 
           request.resource.data.status == 'cancelled') ||
          // Seller can mark as shipped (for physical goods)
          (resource.data.sellerId == request.auth.uid && 
           resource.data.status == 'completed' && 
           request.resource.data.status == 'shipped')
        );
      
      // No deletes - transactions are permanent records
      allow delete: if false;
    }
    
    // Shopping carts
    match /carts/{userId} {
      // Users can only access their own cart
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      
      // Cart items subcollection
      match /items/{itemId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }
    
    // Seller stats/profiles
    match /seller_stats/{userId} {
      // Public read for marketplace display
      allow read: if isAuthenticated();
      
      // Only the seller can initialize
      allow create: if isOwner(userId);
      
      // Stats should be updated via Cloud Functions after transactions
      // Allow limited self-updates for profile info
      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['storeName', 'storeDescription', 'updatedAt']);
    }

    // =========================================================================
    // Generated Content / History
    // =========================================================================
    match /history/{historyId} {
      // Users can read their own history or org history
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         (resource.data.orgId != null && isOrgMember(resource.data.orgId)));
      
      // Users can create history entries
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      
      // Users can update their own history
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      
      // Users can delete their own history
      allow delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // Check if the authenticated user is Anonymous
    function isAnonymous() {
      return isAuthenticated() &&
             request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    // Check if user is a verified (non-anonymous) authenticated user.
    function isVerifiedUser() {
      return isAuthenticated() && !isAnonymous();
    }

    // =========================================================================
    // Knowledge Base / RAG Documents
    // =========================================================================
    match /knowledge/{docId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid ||
         (resource.data.orgId != null && isOrgMember(resource.data.orgId)));
      
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      
      allow update, delete: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
    }

    // =========================================================================
    // Publishing Registrations (verified users only — PRO/MLC filings)
    // =========================================================================
    match /publishing_registrations/{registrationId} {
      allow read: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow create: if isVerifiedUser() && request.resource.data.userId == request.auth.uid;
      allow update: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // =========================================================================
    // Split Escrows (verified users only — financial holds)
    // =========================================================================
    match /split_escrows/{escrowId} {
      allow read: if isVerifiedUser() && (
        resource.data.initiatorUid == request.auth.uid ||
        request.auth.uid in resource.data.parties
      );
      allow create: if isVerifiedUser() && request.resource.data.initiatorUid == request.auth.uid;
      allow update: if isVerifiedUser() && request.auth.uid in resource.data.parties;
      allow delete: if false;
    }

    // =========================================================================
    // Audit Logs (read-only — written by Cloud Functions only)
    // System Audit logs: Only readable by Admins
    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    // =========================================================================
    // Push Notification Tokens (user-scoped)
    // =========================================================================
    match /notification_tokens/{tokenId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // =========================================================================
    // Cross-Device Handoff (user-scoped subcollection)
    // =========================================================================
    match /users/{userId}/handoff/{stateId} {
      allow read, write: if isOwner(userId);
    }

    // =========================================================================
    // Memory Architecture — 5-Layer System (user-scoped subcollections)
    // =========================================================================

    // Layer 3: CORE Vault — Authoritative fact store (supersede-never-delete)
    match /users/{userId}/vault/{category} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      // Facts are superseded, never deleted — enforced at app layer
      allow delete: if false;
    }

    // Layer 4: Captain's Logs — Daily append-only operational timeline
    match /users/{userId}/captains_logs/{dateKey} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      // Entries can only be appended (arrayUnion), never removed
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Layer 1: Session Transcripts — Durable session history for Squeezer search
    match /users/{userId}/session_transcripts/{sessionId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Layer 2: Deep Hive — Episodic memory store
    match /users/{userId}/memories/{memoryId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Layer 2: Deep Hive — Consolidated insights
    match /users/{userId}/insights/{insightId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // AlwaysOnMemoryEngine — Always-on memory ingestion & consolidation
    match /users/{userId}/alwaysOnMemories/{memoryId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/consolidationInsights/{insightId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/ingestionEvents/{eventId} {
      allow read, write: if isOwner(userId);
    }

    // =========================================================================
    // Remote Relay (Firestore Cloud Relay — phone ↔ desktop)
    // =========================================================================
    
    // Desktop state document
    match /users/{userId}/remote-relay/{docId} {
      allow read, write: if isOwner(userId);
    }
    
    // Commands (phone writes, desktop reads/updates)
    match /users/{userId}/remote-relay-commands/{commandId} {
      allow read, write: if isOwner(userId);
    }
    
    // Responses (desktop writes, phone reads)
    match /users/{userId}/remote-relay-responses/{responseId} {
      allow read, write: if isOwner(userId);
    }

    // =========================================================================
    // Licensing Clearances
    // =========================================================================
    match /licensing_clearances/{clearanceId} {
      allow read: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow create: if isVerifiedUser() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // =========================================================================
    // Label Deals
    // =========================================================================
    match /label_deals/{dealId} {
      allow read: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow create: if isVerifiedUser() && request.resource.data.userId == request.auth.uid;
      allow update: if isVerifiedUser() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // =========================================================================
    // Deletion Requests
    // =========================================================================
    match /_deletion_requests/{userId} {
      allow read: if isVerifiedUser() && request.auth.uid == userId;
      allow create: if isVerifiedUser() && request.auth.uid == userId;
      allow update, delete: if false;
    }

    // =========================================================================
    // Deny all other access by default
    // =========================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
