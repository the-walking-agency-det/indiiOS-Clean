{
  "afterAllArtifactBuild": "build/postinstall.sh",
  "afterSign": "build/notarize.js",
  "appId": "com.indii.os.studio",
  "asarUnpack": [
    "**/node_modules/ffmpeg-static/**",
    "**/node_modules/ffprobe-static/**"
  ],
  "buildVersion": "1.0.0",
  "copyright": "Copyright \u00a9 2025 IndiiOS LLC",
  "description": "The Operating System for Independent Artists - Studio Edition with AI-powered creativity tools",
  "directories": {
    "buildResources": "build",
    "output": "dist-electron-studio"
  },
  "exclude": [
    "**/test/**/*",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.md",
    "docs/**/*",
    ".github/**/*",
    "**/.env.example",
    "**/.env.*",
    "!node_modules/@rollup/rollup-linux-x64-gnu/**"
  ],
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "linux": {
    "category": "AudioVideo",
    "target": [
      "AppImage",
      "deb",
      "rpm",
      "tar.gz"
    ]
  },
  "mac": {
    "category": "public.app-category.productivity",
    "darkModeSupport": true,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "CFBundleIdentifier": "com.indii.os.studio",
      "NSAppTransportSecurity": true,
      "apple_event_scanner": "true"
    },
    "gatekeeperAssess": true,
    "hardenedRuntime": true,
    "icon": "assets/icon-studio.icns",
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ]
  },
  "dmg": {
    "background-color": "#0d1117",
    "contents": [
      {
        "path": "dist-electron-studio/indiiOS Studio.app",
        "type": "file",
        "x": 130,
        "y": 220
      },
      {
        "path": "Applications",
        "type": "file",
        "x": 410,
        "y": 220
      }
    ],
    "icon": "assets/icon-studio.icns",
    "iconText": "",
    "window": {
      "title": "indiiOS Studio"
    }
  },
  "nsis": {
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "displayLanguageSelector": true,
    "include": [
      "build/installer.nsh"
    ],
    "installerLanguages": [
      "en_US",
      "en_GB",
      "en_AU"
    ],
    "oneClick": false,
    "perMachine": false
  },
  "npmRebuild": false,
  "productName": "indiiOS Studio",
  "protocols": [
    {
      "name": "indiiOS Studio Auth Protocol",
      "schemes": [
        "indii-os-studio"
      ]
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "the-walking-agency-det",
      "repo": "indiiOS-Alpha-Electron",
      "publishAutoUpdate": true,
      "releaseType": "draft"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      {
        "target": "portable"
      }
    ],
    "uninstallDisplayName": "indiiOS Studio",
    "verifyUpdateCodeSignature": true
  }
}