{
  "afterAllArtifactBuild": "build/postinstall.sh",
  "afterSign": "build/notarize.js",
  "appId": "com.indii.os.studio",
  "asarUnpack": [
    "**/node_modules/ffmpeg-static/**",
    "**/node_modules/ffprobe-static/**"
  ],
  "buildVersion": "1.0.0",
  "copyright": "Copyright \u00a9 2025 IndiiOS LLC",
  "description": "The Operating System for Independent Artists - Studio Edition with AI-powered creativity tools",
  "directories": {
    "buildResources": "build",
    "output": "dist-electron-studio"
  },
  "exclude": [
    "**/test/**/*",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.md",
    "docs/**/*",
    ".github/**/*",
    "**/.env.example",
    "**/.env.*",
    "!node_modules/@rollup/rollup-linux-x64-gnu/**"
  ],
  "files": [
    "dist/**/*",
    "dist-electron-studio/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "linux": {
    "AppImage": {
      "icon": "assets/icon-studio.png",
      "keywords": [
        "indiiOS",
        "studio",
        "creative",
        "AI",
        "music",
        "art"
      ]
    },
    "category": "AudioVideo",
    "deb": {
      "afterInstall": [
        "ln -sf /opt/indiios-studio/resources ~/Desktop/indiiOS-Studio-Resources"
      ],
      "depends": [
        "ffmpeg",
        "libgconf-2-4",
        "libnotify4"
      ],
      "priority": "optional",
      "synopsis": "indiiOS Studio - Desktop creative studio for independent artists"
    },
    "desktop": {
      "Keywords": "indiiOS Studio;creative;AI;music;art",
      "icon": "assets/icon-studio.png",
      "startupNotify": true
    },
    "icon": "assets/icon-studio.png",
    "rpm": {
      "category": "AudioVideo",
      "icon": "assets/icon-studio.png"
    },
    "target": [
      "AppImage",
      "deb",
      "rpm",
      "tar.gz"
    ]
  },
  "mac": {
    "category": "public.app-category.productivity",
    "darkModeSupport": true,
    "dmg": {
      "background-color": "#0d1117",
      "contents": [
        {
          "path": "dist-electron-studio/indiiOS Studio.app",
          "type": "file",
          "x": 130,
          "y": 220
        },
        {
          "path": "Applications",
          "type": "file",
          "x": 410,
          "y": 220
        }
      ],
      "icon": "assets/icon-studio.icns",
      "iconText": "",
      "window": {
        "title": "indiiOS Studio"
      }
    },
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "CFBundleIdentifier": "com.indii.os.studio",
      "NSAppTransportSecurity": true,
      "apple_event_scanner": "true"
    },
    "gatekeeperAssess": true,
    "hardenedRuntime": true,
    "icon": "assets/icon-studio.icns",
    "target": [
      {
        "arch": [
          "x64",
          "arm64"
        ],
        "target": "dmg",
        "type": "distribution"
      },
      {
        "arch": [
          "x64",
          "arm64"
        ],
        "target": "zip",
        "type": "archive"
      }
    ],
    "zip": {
      "icon": "assets/icon-studio.icns",
      "target": "mac-x64"
    }
  },
  "npmRebuild": false,
  "productName": "indiiOS Studio",
  "protocols": [
    {
      "name": "indiiOS Studio Auth Protocol",
      "schemes": [
        "indii-os-studio"
      ]
    }
  ],
  "publish": {
    "UpdaterCacheDirName": "indiios-studio-updater",
    "generateUpdatesFiles": false,
    "owner": "the-walking-agency-det",
    "provider": "github",
    "publishAutoUpdate": true,
    "releaseType": "draft",
    "repo": "indiiOS-Alpha-Electron"
  },
  "win": {
    "artifacts": [
      {
        "arch": [
          "x64",
          "arm64"
        ],
        "path": "build/installer.nsis",
        "target": "nsis"
      },
      {
        "path": "build/installer-portable.exe",
        "target": "portable"
      }
    ],
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "createUninstallShortcut": true,
    "icon": "assets/icon-studio.ico",
    "installerIcon": "assets/icon-studio.ico",
    "nsis": {
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": true,
      "include": [
        "build/installer.nsh"
      ],
      "installerLanguages": [
        "en_US",
        "en_GB",
        "en_AU"
      ],
      "oneClick": false,
      "perMachine": false
    },
    "requestedExecutionLevel": "asInvoker",
    "runAfterFinish": false,
    "setShortcutRunAsAdmin": false,
    "signDlls": true,
    "target": [
      {
        "arch": [
          "x64",
          "arm64"
        ],
        "target": "nsis"
      },
      {
        "target": "portable"
      }
    ],
    "uninstallDisplayName": "indiiOS Studio",
    "verifyUpdateCodeSignature": true
  }
}
