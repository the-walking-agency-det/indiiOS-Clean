{
  "afterAllArtifactBuild": "build/postinstall.sh",
  "afterSign": "build/notarize.js",
  "appId": "com.indii.os.studio",
  "asarUnpack": [
    "**/node_modules/ffmpeg-static/**",
    "**/node_modules/ffprobe-static/**"
  ],
  "buildVersion": "1.0.0",
  "copyright": "Copyright \u00a9 2025 IndiiOS LLC",
  "directories": {
    "buildResources": "build",
    "output": "dist-electron-studio"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "node_modules/**/*",
    "package.json",
    "!**/test/**/*",
    "!**/*.spec.ts",
    "!**/*.spec.tsx",
    "!**/*.md",
    "!docs/**/*",
    "!.github/**/*",
    "!**/.env.example",
    "!**/.env.*"
  ],
  "linux": {
    "category": "AudioVideo",
    "target": [
      "AppImage",
      "deb",
      "rpm",
      "tar.gz"
    ]
  },
  "mac": {
    "category": "public.app-category.productivity",
    "darkModeSupport": true,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "extendInfo": {
      "CFBundleIdentifier": "com.indii.os.studio",
      "NSAppTransportSecurity": true,
      "apple_event_scanner": "true"
    },
    "gatekeeperAssess": true,
    "hardenedRuntime": true,
    "icon": "assets/icon-studio.icns",
    "target": [
      "dmg",
      "zip"
    ]
  },
  "dmg": {
    "backgroundColor": "#0d1117",
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "icon": "assets/icon-studio.icns",
    "window": {}
  },
  "nsis": {
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "displayLanguageSelector": true,
    "include": "build/installer.nsh",
    "installerLanguages": [
      "en_US",
      "en_GB",
      "en_AU"
    ],
    "oneClick": false,
    "perMachine": false,
    "uninstallDisplayName": "indiiOS Studio"
  },
  "npmRebuild": false,
  "productName": "indiiOS Studio",
  "protocols": [
    {
      "name": "indiiOS Studio Auth Protocol",
      "schemes": [
        "indii-os-studio"
      ]
    }
  ],
  "publish": [
    {
      "provider": "github",
      "owner": "the-walking-agency-det",
      "repo": "indiiOS-Alpha-Electron",
      "publishAutoUpdate": true,
      "releaseType": "draft"
    }
  ],
  "win": {
    "target": [
      "nsis",
      "portable"
    ],
    "verifyUpdateCodeSignature": true
  }
}