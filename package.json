{
  "name": "indiios-monorepo",
  "version": "1.50.0",
  "description": "The Operating System for Independent Artists — npm Workspace Monorepo",
  "author": "IndiiOS LLC <info@indiios.com>",
  "private": true,
  "main": "dist/main/index.js",
  "workspaces": [
    "packages/main",
    "packages/renderer",
    "packages/firebase",
    "packages/shared",
    "packages/landing"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:studio": "npm run build",
    "build:firebase": "npm run build -w packages/firebase",
    "build:landing": "npm run build -w packages/landing",
    "build:full": "npm run typecheck && npm run lint && electron-vite build",
    "deploy": "electron-vite build && firebase deploy --only hosting:app",
    "deploy:functions": "npm run build -w packages/firebase && firebase deploy --only functions",
    "deploy:landing": "npm run build -w packages/landing && firebase deploy --only hosting:landing",
    "deploy:all": "npm run build && npm run build:firebase && npm run build:landing && firebase deploy",
    "typecheck": "tsc -b packages/shared packages/main packages/renderer",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "lint:fix": "eslint packages/*/src --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:renderer": "vitest --project packages/renderer",
    "test:main": "vitest --project packages/main",
    "test:e2e": "npx playwright test --project=chromium",
    "test:rules": "FIRESTORE_EMULATOR_HOST=localhost:8080 vitest run --config vitest.rules.config.ts",
    "lint:renderer": "eslint packages/renderer/src --ext .ts,.tsx",
    "lint:main": "eslint packages/main/src --ext .ts,.tsx",
    "typecheck:renderer": "tsc -b packages/renderer",
    "typecheck:main": "tsc -b packages/main",
    "desktop:dev": "electron-vite dev",
    "electron:build": "electron-vite build && electron-builder --publish never",
    "changelog": "bash scripts/generate-changelog.sh",
    "changelog:update": "bash scripts/generate-changelog.sh --prepend"
  },
  "devDependencies": {
    "@ai-sdk/google": "^3.0.60",
    "@electron/rebuild": "3.7.1",
    "@eslint/js": "9.39.1",
    "@mastra/core": "^1.24.1",
    "@mastra/mcp": "^1.4.2",
    "@playwright/test": "^1.58.2",
    "axe-core": "4.11.1",
    "dotenv": "^17.2.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "esbuild": "0.25.12",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "lightningcss": "1.30.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "8.48.0",
    "vitest": "4.0.18"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.25.12",
    "@rollup/rollup-linux-x64-gnu": "4.53.3",
    "@tailwindcss/oxide-linux-x64-gnu": "4.1.18",
    "canvas": "3.2.0",
    "cpu-features": "0.0.10",
    "lightningcss-linux-x64-gnu": "1.30.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "files": [
      "dist/**/*",
      "python/**/*",
      "package.json",
      "!node_modules/@rollup/rollup-linux-x64-gnu",
      "!node_modules/@esbuild"
    ],
    "mac": {
      "gatekeeperAssess": true,
      "hardenedRuntime": true
    },
    "npmRebuild": false,
    "protocols": [
      {
        "name": "indii-os",
        "schemes": [
          "indii-os"
        ]
      }
    ],
    "publish": [
      {
        "owner": "the-walking-agency-det",
        "private": true,
        "provider": "github",
        "repo": "indiiOS-Alpha-Electron"
      }
    ],
    "win": {
      "verifyUpdateCodeSignature": true
    }
  },
  "overrides": {
    "zod": "3.25.76",
    "@genkit-ai/firebase": "1.26.0",
    "@genkit-ai/google-cloud": "1.26.0",
    "fast-xml-parser": "5.5.10"
  }
}